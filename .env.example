# ─── Database ────────────────────────────────────────────────
POSTGRES_USER=dakwah
POSTGRES_PASSWORD=dakwah_dev
POSTGRES_DB=dakwah_lens
DATABASE_URL=postgresql+asyncpg://dakwah:dakwah_dev@localhost:5433/dakwah_lens

# ─── Qdrant ──────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ─── Redis (Celery broker) ───────────────────────────────────
REDIS_URL=redis://localhost:6380/0

# ─── Auth ────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Bootstrap admin — first signup with this email is auto-approved as admin
# (user management at /admin/users).
ADMIN_EMAIL=

# Bootstrap superadmin — first signup with this email is auto-approved as
# superadmin (full /admin/system observability + cost dashboard).
# If the same address is in both, SUPERADMIN_EMAIL wins.
SUPERADMIN_EMAIL=

# ─── Email (verification + reset) ─────────────────────────────
# Optional — when unset, the app logs verification/reset links to the
# server console so dev flows still work. Set RESEND_API_KEY to send
# real emails via Resend (https://resend.com — 3K/month free tier).
RESEND_API_KEY=
# Sender shown in the From: header. For dev, the Resend sandbox value
# "onboarding@resend.dev" is fine; for production, use a verified domain.
EMAIL_FROM=Dakwah-Lens <onboarding@resend.dev>

# ─── LLM / Embeddings ────────────────────────────────────────
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Default models
EMBEDDING_MODEL=text-embedding-3-large
CLASSIFIER_MODEL=gemini-2.0-flash
BRIEF_MODEL=claude-sonnet-4-6

# ─── Scrapers ────────────────────────────────────────────────
APIFY_TOKEN=
YOUTUBE_API_KEY=

# ─── App ─────────────────────────────────────────────────────
API_BASE_URL=http://localhost:8000
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=en,id

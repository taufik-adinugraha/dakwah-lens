# ─────────────────────────────────────────────────────────────────
# Production env template for dakwah-lens.id on the IDCloudHost VM.
#
# Copy this to `/srv/dakwah-lens/repo/.env` on the VM and fill in the
# blanks. Do NOT commit the populated file.
#
# Anything left empty here will either fall back to a safe default in
# code (the email helper logs to console when RESEND_API_KEY is unset,
# for example) OR cause a feature to be disabled. None of the empties
# block the app from starting.
# ─────────────────────────────────────────────────────────────────

# ─── Database ────────────────────────────────────────────────
# These set the Postgres credentials used by every service. The web
# (Drizzle) and api (asyncpg/SQLAlchemy) services build their own
# DATABASE_URL from these — no need to set DATABASE_URL separately.
POSTGRES_USER=dakwah
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=dakwah_lens

# ─── Auth (NextAuth) ─────────────────────────────────────────
# Must be the public origin — NextAuth uses it to build callback URLs.
NEXTAUTH_URL=https://dakwah-lens.id
# Generate once with: openssl rand -base64 32
# Rotating this signs everyone out — only do it intentionally.
NEXTAUTH_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_32

# Google OAuth — set both or leave both blank. With both set, the
# "Continue with Google" button appears on /login.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# First signup with this email is auto-approved as admin / superadmin.
# Set BEFORE the first user signs up — once set, leave it.
ADMIN_EMAIL=
SUPERADMIN_EMAIL=taufik.adinugraha@gmail.com

# ─── Email (Resend) ──────────────────────────────────────────
# When unset, verification + reset emails print to the api container's
# stdout (visible via `docker compose logs api`). Set for prod.
RESEND_API_KEY=
# Use the Resend-verified sender once dakwah-lens.id is verified there.
EMAIL_FROM=Dakwah-Lens <noreply@dakwah-lens.id>

# ─── LLM / Embeddings ────────────────────────────────────────
# All three are optional in code (we fall back through providers), but
# without at least one of OpenAI / Gemini / Anthropic, brief generation
# won't work. OpenAI is required for kitab retrieval (embeddings).
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Pinned defaults — override only if Gemini changes pricing or a new
# Sonnet ships. Code reads these on every brief call.
EMBEDDING_MODEL=text-embedding-3-large
CLASSIFIER_MODEL=gemini-2.0-flash
BRIEF_MODEL=claude-sonnet-4-6

# ─── Scrapers ────────────────────────────────────────────────
# Apify drives X / Instagram / TikTok ingest. Without a token, those
# Celery tasks fail silently and ingest just covers RSS + YouTube.
APIFY_TOKEN=
# YouTube Data API key — separate from Apify. Used directly (cheaper
# than the Apify YouTube actor).
YOUTUBE_API_KEY=

# ─── Qdrant (vector store) ───────────────────────────────────
# Local Qdrant container needs no API key. If we ever swap to Qdrant
# Cloud, set this to the cluster's API key.
QDRANT_API_KEY=
